  <Source dwd:design-time-name="2a2815e9-e307-4494-a419-9a587910ce34">
    <DataSourceViewID>GFRS DW</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="fb013a0d-54b3-4316-8083-8d937578305a">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>
CALCULATE;        
CREATE MEMBER CURRENTCUBE.[Measures].[Prev Quarter Qty]
 AS (
    PARALLELPERIOD(
        [Dim DATE].[Hierarchy].[Quarter Of Purchase], 
        1,                              
        [Dim Date].[Hierarchy].CurrentMember
    ),
    [Measures].[Line Total]
), 
FORMAT_STRING = "Standard",
VISIBLE = 1;        

/* Measure 2: Tỷ lệ tăng trưởng */
CREATE MEMBER CURRENTCUBE.[Measures].[Growth Rate]
 AS (CASE
    -- Kiểm tra mẫu số bằng 0 hoặc Null
    WHEN [Measures].[Prev Quarter Qty] = 0 OR IsEmpty([Measures].[Prev Quarter Qty]) 
    THEN NULL
    
    -- Tính toán
    ELSE 
        (
          ([Measures].[Line Total] - [Measures].[Prev Quarter Qty]) 
          / [Measures].[Prev Quarter Qty]
        )
END), 
FORMAT_STRING = "Percent", 
VISIBLE = 1;      
  
CREATE MEMBER CURRENTCUBE.[Measures].[3 Month Rolling Avg]
AS AVG(
        LASTPERIODS(3, [Dim Date].[Hierarchy].CurrentMember), 
        [Measures].[Line Total]
    ),
FORMAT_STRING = "Standard", 
VISIBLE = 1;      

-- Đếm số lượng khách hàng mua lại sản phẩm
CREATE MEMBER CURRENTCUBE.[Measures].[Repurchase Customer Count]
AS COUNT(
    FILTER(
        EXISTING [Dim CUSTOMER].[Customer ID].[Customer ID].MEMBERS,
        (
            [Measures].[Fact TRANSACTIONS Count],
            [Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2]
        ) &gt; 1
    )
),
VISIBLE = 1;

-- Đếm số lượng khách hàng đã mua
CREATE MEMBER CURRENTCUBE.[Measures].[Unique Customer Count]
AS COUNT(
    NONEMPTY([Dim CUSTOMER].[Customer ID].[Customer ID].MEMBERS,
        [Measures].[Line Total]
    )
), VISIBLE = 1;

-- Tỷ lệ yêu thích
CREATE MEMBER CURRENTCUBE.[Measures].[Product Repurchase Rate]
AS
    IIF ([Measures].[Unique Customer Count] = 0,
        NULL,
        [Measures].[Repurchase Customer Count]
        /
        [Measures].[Unique Customer Count]
    ),
FORMAT_STRING = "Percent",
VISIBLE = 1;

CREATE MEMBER CURRENTCUBE.[Measures].[Sales of Top 10 Products]
 AS SUM(
        TOPCOUNT(
            -- Lấy Top 10 trong danh sách sản phẩm hiện có
            EXISTING [Dim Products].[Product ID].[Product ID].MEMBERS,
            10,
            [Measures].[Line Total]
        ),
        [Measures].[Line Total]
    ), 
FORMAT_STRING = "#,##0.00", 
VISIBLE = 1;     


CREATE MEMBER CURRENTCUBE.[Measures].[Sales of Bottom 10 Products]
AS 
    SUM(
        BOTTOMCOUNT(
            -- Lọc ra các sản phẩm có bán được hàng (&gt; 0) trước khi xếp hạng chót
            FILTER(
                EXISTING [Dim Products].[Product ID].[Product ID].MEMBERS,
                [Measures].[Line Total] &gt; 0
            ),
            10,
            [Measures].[Line Total]
        ),
        [Measures].[Line Total]
    ),
FORMAT_STRING = "#,##0.00",
VISIBLE = 1;     


CREATE MEMBER CURRENTCUBE.[Measures].[Top 5 Product Contribution %]
AS 
    IIF([Measures].[Line Total] = 0, NULL,
        -- Tử số: Tổng tiền của Top 5
        SUM(
            TOPCOUNT(
                EXISTING [Dim Products].[Product ID].[Product ID].MEMBERS,
                5, 
                [Measures].[Line Total]
            ), 
            [Measures].[Line Total]
        )
        /
        -- Mẫu số: Tổng tiền toàn bộ sản phẩm (dùng All)
        ([Dim Products].[Product ID].[All], [Measures].[Line Total])
    ),
FORMAT_STRING = "Percent",
VISIBLE = 1;     

CREATE MEMBER CURRENTCUBE.[Measures].[Hero vs Zero Ratio]
AS 
    IIF(
        [Measures].[Sales of Bottom 10 Products] = 0, 
        NULL, -- Tránh lỗi chia cho 0
        [Measures].[Sales of Top 10 Products] 
        / 
        [Measures].[Sales of Bottom 10 Products]
    ),
FORMAT_STRING = "#,##0.0x", -- Hiển thị dạng "50.0x" (lần)
VISIBLE = 1;     

CREATE MEMBER CURRENTCUBE.[Measures].[Discount Affinity %]
AS 
    IIF([Measures].[Line Total] = 0, NULL,
        -- Tử số: Tổng tiền của các giao dịch có Discount &gt; 0
        SUM(
            FILTER(
                EXISTING [Dim Discounts].[Discount].[Discount].MEMBERS,
                [Dim Discounts].[Discount].CurrentMember.MemberValue &gt; 0
            ),
            [Measures].[Line Total]
        )
        /
        -- Mẫu số: Tổng doanh thu
        [Measures].[Line Total]
    ),
FORMAT_STRING = "Percent", VISIBLE = 1;     

CREATE MEMBER CURRENTCUBE.[Measures].[Revenue YTD]
AS 
    SUM(
        PERIODSTODATE(
            [Dim Date].[Hierarchy].[Year Of Purchase], -- Tham số 1: Điểm mốc để Reset (Cấp Năm)
            [Dim Date].[Hierarchy].CurrentMember -- Tham số 2: Vị trí hiện tại
        ),
        [Measures].[Line Total]
    ),
FORMAT_STRING = "#,##0.00",
VISIBLE = 1;     

-- Measure tính số lượng đơn hàng có giảm giá
CREATE MEMBER CURRENTCUBE.[Measures].[Discounted Quantity]
AS SUM(
    FILTER(
        [Dim DISCOUNTS].[Discount].[Discount].MEMBERS,
        [Dim DISCOUNTS].[Discount].CurrentMember.Member_Value &gt;0
    ),
    ([Measures].[Quantity],[Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2])
),VISIBLE = 1; 

-- Measure tính số lượng đơn hàng bán đúng giá 
CREATE MEMBER CURRENTCUBE.[Measures].[Full Price Quantity]
AS ([Measures].[Quantity],[Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2]) - [Measures].[Discounted Quantity],
VISIBLE = 1; 

-- Measure tính tỷ lệ khuyến mãi
CREATE MEMBER CURRENTCUBE.[Measures].[Discount Penetration %]
 AS IIF(
    ([Measures].[Quantity],[Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2]) = 0,
    NULL,
    [Measures].[Discounted Quantity]
    /
    ([Measures].[Quantity],[Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2])
), 
FORMAT_STRING = "Percent", 
VISIBLE = 1  ; 

/* ------------------------------------------------------
   PARETO ANALYSIS FOR SUB CATEGORIES
   ------------------------------------------------------ */

/* 1. Xếp hạng SubCategory theo Số lượng bán (Rank) */
CREATE MEMBER CURRENTCUBE.[Measures].[SubCat Rank]
 AS RANK(
        [Dim PRODUCTS - Sub Category].[Sub Category].CurrentMember,
        ORDER(
            [Dim PRODUCTS - Sub Category].[Sub Category].[Sub Category].MEMBERS,
            ( [Measures].[Quantity], [Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2] ),
            BDESC
        )
    ), 
VISIBLE = 0;    -- Chỉ dùng để tính toán nội bộ

/* 2. Tính tổng lũy kế (Cumulative Quantity)
   Logic: Cộng dồn số lượng từ SubCategory hạng 1 đến hạng hiện tại
*/
CREATE MEMBER CURRENTCUBE.[Measures].[SubCat Cumulative Quantity]
 AS SUM(
        TOPCOUNT(
            [Dim PRODUCTS - Sub Category].[Sub Category].[Sub Category].MEMBERS,
            [Measures].[SubCat Rank],
            ( [Measures].[Quantity], [Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2] )
        ),
        ( [Measures].[Quantity], [Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2] )
    ), 
VISIBLE = 1;   

/* 3. Tính % Pareto
   Logic: (Lũy kế / Tổng tất cả SubCategories)
   Sử dụng hàm ROOT() để lấy tổng toàn bộ Dimension bất kể đang lọc cái gì
*/
CREATE MEMBER CURRENTCUBE.[Measures].[SubCat Pareto %]
 AS IIF(
    -- 1. Kiểm tra: Tổng Quantity SALE toàn bộ danh mục có bằng 0 không?
    (ROOT([Dim PRODUCTS - Sub Category]), [Measures].[Quantity], [Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2]) = 0,
    NULL,
    
    -- 2. Tử số: Lấy Cumulative Quantity của SALE
    ([Measures].[SubCat Cumulative Quantity], [Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2]) 
    /
    -- 3. Mẫu số: Chia cho Tổng Quantity SALE toàn bộ danh mục
    (ROOT([Dim PRODUCTS - Sub Category]), [Measures].[Quantity], [Dim TRANSACTIONTYPE].[Transaction Type ID].&amp;[2])
), 
FORMAT_STRING = "Percent", 
VISIBLE = 1; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>